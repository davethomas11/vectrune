{
  "name": "rune",
  "displayName": "Vectrune Language Support",
  "description": "Syntax highlighting and language support for Vectrune (.rune) files",
  "version": "0.1.0",
  "publisher": "vectrune",
  "repository": {
    "type": "git",
    "url": "https://github.com/davethomas11/vectrune"
  },
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rune",
        "aliases": [
          "Vectrune",
          "vectrune",
          "rune"
        ],
        "extensions": [
          ".rune"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rune",
        "scopeName": "source.rune",
        "path": "./.github/linguist/rune.tmLanguage"
      }
    ]
  }
}



